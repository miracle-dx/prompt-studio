"use client";

import { cn } from "@/lib/utils";
import {
  Library,
  Star,
  Clock,
  Settings,
  Plus,
  Search,
  Sparkles,
  Folder,
  FileText,
  ChevronRight,
  Trash2,
  Pencil,
} from "lucide-react";
import { useState, useRef, useEffect } from "react";
import { useAppStore } from "@/lib/store";
import { formatTime } from "@/lib/types";
import { ConfirmDialog } from "@/components/ui/modal";

export function Sidebar() {
  const [expandedFolders, setExpandedFolders] = useState<string[]>(["work"]);
  const [deleteDialogOpen, setDeleteDialogOpen] = useState(false);
  const [deleteFolderDialogOpen, setDeleteFolderDialogOpen] = useState(false);
  const [promptToDelete, setPromptToDelete] = useState<string | null>(null);
  const [folderToDelete, setFolderToDelete] = useState<string | null>(null);
  const [editingFolderId, setEditingFolderId] = useState<string | null>(null);
  const [editingFolderName, setEditingFolderName] = useState("");
  const inputRef = useRef<HTMLInputElement>(null);

  const {
    folders,
    prompts,
    searchQuery,
    setSearchQuery,
    activePromptId,
    setActivePrompt,
    createPrompt,
    deletePrompt,
    createFolder,
    updateFolder,
    deleteFolder,
    activeView,
    setActiveView,
  } = useAppStore();

  // 编辑时自动聚焦输入框
  useEffect(() => {
    if (editingFolderId && inputRef.current) {
      inputRef.current.focus();
      inputRef.current.select();
    }
  }, [editingFolderId]);

  const toggleFolder = (folder: string) => {
    setExpandedFolders((prev) =>
      prev.includes(folder)
        ? prev.filter((f) => f !== folder)
        : [...prev, folder]
    );
  };

  const handleCreatePrompt = () => {
    createPrompt("work");
  };

  const handleCreateFolder = () => {
    const newFolder = createFolder("新建文件夹");
    setExpandedFolders((prev) => [...prev, newFolder.id]);
    setEditingFolderId(newFolder.id);
    setEditingFolderName("新建文件夹");
  };

  const handleDeleteClick = (promptId: string, e: React.MouseEvent) => {
    e.stopPropagation();
    setPromptToDelete(promptId);
    setDeleteDialogOpen(true);
  };

  const handleConfirmDelete = () => {
    if (promptToDelete) {
      deletePrompt(promptToDelete);
      setPromptToDelete(null);
    }
  };

  const handleDeleteFolderClick = (folderId: string, e: React.MouseEvent) => {
    e.stopPropagation();
    e.preventDefault();
    setFolderToDelete(folderId);
    setDeleteFolderDialogOpen(true);
  };

  const handleConfirmDeleteFolder = () => {
    if (folderToDelete) {
      deleteFolder(folderToDelete);
      setFolderToDelete(null);
    }
  };

  const handleRenameFolder = (folderId: string, e: React.MouseEvent) => {
    e.stopPropagation();
    const folder = folders.find((f) => f.id === folderId);
    if (folder) {
      setEditingFolderId(folderId);
      setEditingFolderName(folder.name);
    }
  };

  const handleSaveRename = () => {
    if (editingFolderId && editingFolderName.trim()) {
      updateFolder(editingFolderId, editingFolderName.trim());
    }
    setEditingFolderId(null);
    setEditingFolderName("");
  };

  const handleRenameKeyDown = (e: React.KeyboardEvent) => {
    if (e.key === "Enter") {
      handleSaveRename();
    } else if (e.key === "Escape") {
      setEditingFolderId(null);
      setEditingFolderName("");
    }
  };

  // 获取每个文件夹下的 Prompt
  const getPromptsByFolder = (folderId: string) => {
    return prompts
      .filter((p) => p.folderId === folderId)
      .sort((a, b) => b.updatedAt - a.updatedAt);
  };

  return (
    <>
      <aside className="w-[280px] flex-shrink-0 border-r border-gray-200 dark:border-gray-700 flex flex-col h-screen bg-gray-50 dark:bg-gray-900">
      {/* Logo 区域 */}
      {/* Logo 区域 */}
      <div className="p-4 border-b border-gray-200 dark:border-gray-700 flex-shrink-0">
        <div className="flex items-center gap-3 mb-4">
          <div className="w-9 h-9 rounded-lg bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center shadow-md">
            <Sparkles className="w-5 h-5 text-white" />
          </div>
          <span className="font-semibold text-lg text-gray-900 dark:text-white">
            Prompt Studio
          </span>
        </div>
        <button
          onClick={handleCreatePrompt}
          className="w-full flex items-center justify-center gap-2 bg-blue-500 hover:bg-blue-600 text-white h-9 px-4 rounded-md text-sm font-medium transition-all duration-150 shadow-sm hover:shadow"
        >
          <Plus className="w-4 h-4" />
          新建 Prompt
        </button>
      </div>

      {/* 搜索框 */}
      <div className="p-3 flex-shrink-0">
        <div className="relative">
          <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500 dark:text-gray-400" />
          <input
            type="text"
            placeholder="搜索 Prompt..."
            value={searchQuery}
            onChange={(e) => setSearchQuery(e.target.value)}
            className="w-full pl-9 h-9 text-sm bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-900 dark:text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          />
        </div>
      </div>

      {/* 导航菜单 - 可滚动区域 */}
      <nav className="px-3 pb-2 space-y-1 flex-1 overflow-y-auto min-h-0">
        {/* Prompt 库 */}
        <button
          onClick={() => setActiveView("library")}
          className={cn(
            "w-full flex items-center gap-3 h-9 px-3 rounded-md text-sm transition-all duration-150 flex-shrink-0",
            activeView === "library"
              ? "bg-gray-100 dark:bg-gray-800 text-blue-600 dark:text-blue-400 font-medium"
              : "text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800"
          )}
        >
          <Library className="w-4 h-4" />
          <span>Prompt 库</span>
        </button>

        {/* 文件夹列表 - 作为 Prompt 库的子内容缩进显示 */}
        {activeView === "library" && searchQuery.trim() === "" && (
          <div className="ml-4 space-y-1 mt-1">
            {/* 新建文件夹按钮 */}
            <button
              onClick={handleCreateFolder}
              className="w-full flex items-center gap-2 h-8 px-2 rounded-md text-sm text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-all duration-150"
            >
              <Plus className="w-3.5 h-3.5" />
              <span>新建文件夹</span>
            </button>
            
            {/* 文件夹列表 */}
            {folders.map((folder) => {
              const isExpanded = expandedFolders.includes(folder.id);
              const folderPrompts = getPromptsByFolder(folder.id);
              const isEditing = editingFolderId === folder.id;

              return (
                <div key={folder.id} className="space-y-1">
                  {/* 文件夹标题 */}
                  <div className="group relative">
                    {isEditing ? (
                      <div className="flex items-center gap-2 h-8 px-2">
                        <ChevronRight
                          className={cn(
                            "w-4 h-4 transition-transform duration-150 text-gray-400",
                            isExpanded && "rotate-90"
                          )}
                        />
                        <Folder className="w-4 h-4 text-gray-400" />
                        <input
                          ref={inputRef}
                          type="text"
                          value={editingFolderName}
                          onChange={(e) => setEditingFolderName(e.target.value)}
                          onBlur={handleSaveRename}
                          onKeyDown={handleRenameKeyDown}
                          className="flex-1 h-6 px-1 text-sm bg-white dark:bg-gray-800 border border-blue-500 text-gray-900 dark:text-white rounded focus:outline-none focus:ring-2 focus:ring-blue-500"
                          onClick={(e) => e.stopPropagation()}
                        />
                      </div>
                    ) : (
                      <button
                        onClick={() => toggleFolder(folder.id)}
                        className="w-full flex items-center gap-2 h-8 px-2 rounded-md text-sm text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-all duration-150 pr-12"
                      >
                        <ChevronRight
                          className={cn(
                            "w-4 h-4 transition-transform duration-150",
                            isExpanded && "rotate-90"
                          )}
                        />
                        <Folder className="w-4 h-4" />
                        <span className="font-medium flex-1 text-left min-w-0 truncate">
                          {folder.name}
                        </span>
                        <span className="text-xs flex-shrink-0">
                          {folderPrompts.length}
                        </span>
                      </button>
                    )}

                    {/* 文件夹操作按钮 - hover 时显示 */}
                    {!isEditing && (
                      <div className="absolute right-1 top-1/2 -translate-y-1/2 flex items-center gap-0.5 opacity-0 group-hover:opacity-100 transition-all duration-150">
                        <button
                          onClick={(e) => handleRenameFolder(folder.id, e)}
                          className="w-5 h-5 flex items-center justify-center rounded text-gray-400 hover:text-blue-500 hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-all duration-150 flex-shrink-0"
                          title="重命名"
                        >
                          <Pencil className="w-3 h-3" />
                        </button>
                        <button
                          onClick={(e) => handleDeleteFolderClick(folder.id, e)}
                          className="w-5 h-5 flex items-center justify-center rounded text-gray-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-all duration-150 flex-shrink-0"
                          title="删除"
                        >
                          <Trash2 className="w-3 h-3" />
                        </button>
                      </div>
                    )}
                  </div>

                  {/* 文件夹内容 */}
                  {isExpanded && (
                <div className="ml-4 space-y-1">
                  {folderPrompts.length === 0 ? (
                    <div className="h-8 px-2 flex items-center text-xs text-gray-400 dark:text-gray-500">
                      暂无 Prompt
                    </div>
                  ) : (
                    folderPrompts.map((prompt) => (
                      <div key={prompt.id} className="group relative">
                        <button
              onClick={() => {
                setActivePrompt(prompt.id);
              }}
                          className={cn(
                            "w-full flex items-center gap-2 h-8 px-2 rounded-md text-sm transition-all duration-150 pr-12",
                            activePromptId === prompt.id
                              ? "bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 font-medium"
                              : "text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800"
                          )}
                        >
                          <FileText className="w-4 h-4 opacity-60 flex-shrink-0" />
                          <span className="flex-1 truncate text-left min-w-0">
                            {prompt.title}
                          </span>
                          <span
                            className={cn(
                              "text-xs flex-shrink-0 opacity-0 group-hover:opacity-100 transition-opacity",
                              activePromptId === prompt.id && "opacity-100"
                            )}
                          >
                            {formatTime(prompt.updatedAt)}
                          </span>
                        </button>
                        {/* 删除按钮 - hover 时显示 */}
                        <button
                          onClick={(e) => handleDeleteClick(prompt.id, e)}
                          className="absolute right-1 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center rounded text-gray-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 opacity-0 group-hover:opacity-100 transition-all duration-150 flex-shrink-0"
                          title="删除"
                        >
                          <Trash2 className="w-3.5 h-3.5" />
                        </button>
                      </div>
                    ))
                  )}
                </div>
              )}
            </div>
          )}
        })}
      </div>
    )}

    {/* 搜索结果 - 有搜索关键词时显示 */}
    {activeView === "library" && searchQuery.trim() !== "" && (
      <div className="ml-4 space-y-1 mt-1">
        <div className="text-xs text-gray-500 dark:text-gray-400 px-2 py-1">
          搜索结果
        </div>
        {(() => {
          const query = searchQuery.toLowerCase();
          const matchedPrompts = prompts.filter(
            (p) =>
              p.title.toLowerCase().includes(query) ||
              p.content.toLowerCase().includes(query)
          );
          
          if (matchedPrompts.length === 0) {
            return (
              <div className="h-8 px-2 flex items-center text-xs text-gray-400 dark:text-gray-500">
                未找到匹配的 Prompt
              </div>
            );
          }

          // 标题匹配的排在前面
          const titleMatched = matchedPrompts.filter((p) =>
            p.title.toLowerCase().includes(query)
          );
          const contentMatched = matchedPrompts.filter(
            (p) => !p.title.toLowerCase().includes(query)
          );

          return [...titleMatched, ...contentMatched].map((prompt) => (
            <div key={prompt.id} className="group relative">
              <button
                onClick={() => {
                  setActivePrompt(prompt.id);
                }}
                className={cn(
                  "w-full flex flex-col items-start py-2 px-2 rounded-md text-sm transition-all duration-150 pr-12",
                  activePromptId === prompt.id
                    ? "bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 font-medium"
                    : "text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800"
                )}
              >
                <div className="flex items-center w-full gap-2">
                  <FileText className="w-4 h-4 opacity-60 flex-shrink-0" />
                  <span className="flex-1 truncate text-left min-w-0 font-medium">
                    {prompt.title}
                  </span>
                  <span
                    className={cn(
                      "text-xs flex-shrink-0 opacity-0 group-hover:opacity-100 transition-opacity",
                      activePromptId === prompt.id && "opacity-100"
                    )}
                  >
                    {formatTime(prompt.updatedAt)}
                  </span>
                </div>
                {/* 显示内容匹配上下文（如果是正文匹配） */}
                {!prompt.title.toLowerCase().includes(query) && (
                  <div className="ml-6 mt-1 text-xs text-gray-500 dark:text-gray-400 w-full overflow-hidden">
                    <span className="truncate">
                      {prompt.content.slice(0, 60)}
                      {prompt.content.length > 60 && "..."}
                    </span>
                  </div>
                )}
              </button>
              {/* 删除按钮 - hover 时显示 */}
              <button
                onClick={(e) => handleDeleteClick(prompt.id, e)}
                className="absolute right-1 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center rounded text-gray-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 opacity-0 group-hover:opacity-100 transition-all duration-150 flex-shrink-0"
                title="删除"
              >
                <Trash2 className="w-3.5 h-3.5" />
              </button>
            </div>
          ));
        })()}
      </div>
    )}

        {/* 收藏夹 */}
        <button
          onClick={() => setActiveView("favorites")}
          className={cn(
            "w-full flex items-center gap-3 h-9 px-3 rounded-md text-sm transition-all duration-150",
            activeView === "favorites"
              ? "bg-gray-100 dark:bg-gray-800 text-blue-600 dark:text-blue-400 font-medium"
              : "text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800"
          )}
        >
          <Star className="w-4 h-4" />
          <span>收藏夹</span>
        </button>

        {/* 历史记录 */}
        <button
          onClick={() => setActiveView("history")}
          className={cn(
            "w-full flex items-center gap-3 h-9 px-3 rounded-md text-sm transition-all duration-150",
            activeView === "history"
              ? "bg-gray-100 dark:bg-gray-800 text-blue-600 dark:text-blue-400 font-medium"
              : "text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800"
          )}
        >
          <Clock className="w-4 h-4" />
          <span>历史记录</span>
        </button>

        {/* 设置 */}
        <button
          onClick={() => setActiveView("settings")}
          className={cn(
            "w-full flex items-center gap-3 h-9 px-3 rounded-md text-sm transition-all duration-150",
            activeView === "settings"
              ? "bg-gray-100 dark:bg-gray-800 text-blue-600 dark:text-blue-400 font-medium"
              : "text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800"
          )}
        >
          <Settings className="w-4 h-4" />
          <span>设置</span>
        </button>
      </nav>

      {/* 底部统计 - 固定在底部 */}
      <div className="p-4 border-t border-gray-200 dark:border-gray-700 flex-shrink-0">
        <div className="bg-white dark:bg-gray-800 rounded-lg p-3">
          <div className="text-xs text-gray-500 dark:text-gray-400 mb-2">
            今日使用
          </div>
          <div className="flex items-end gap-2">
            <span className="text-2xl font-bold text-gray-900 dark:text-white">
              {prompts.length}
            </span>
            <span className="text-xs text-gray-500 dark:text-gray-400 mb-1">
              个 Prompt
            </span>
          </div>
          <div className="mt-2 h-1.5 bg-gray-100 dark:bg-gray-700 rounded-full overflow-hidden">
            <div className="h-full w-2/3 bg-gradient-to-r from-blue-400 to-blue-600 rounded-full" />
          </div>
        </div>
      </div>
    </aside>

    {/* 删除 Prompt 确认弹窗 */}
    <ConfirmDialog
      isOpen={deleteDialogOpen}
      onClose={() => setDeleteDialogOpen(false)}
      onConfirm={handleConfirmDelete}
      title="删除 Prompt"
      message={`确定要删除「${prompts.find((p) => p.id === promptToDelete)?.title || ''}」吗？此操作无法撤销。`}
      confirmText="删除"
      variant="danger"
    />

    {/* 删除文件夹确认弹窗 */}
    <ConfirmDialog
      isOpen={deleteFolderDialogOpen}
      onClose={() => setDeleteFolderDialogOpen(false)}
      onConfirm={handleConfirmDeleteFolder}
      title="删除文件夹"
      message={`确定要删除「${folders.find((f) => f.id === folderToDelete)?.name || ''}」吗？文件夹内的所有 Prompt 也会被删除，此操作无法撤销。`}
      confirmText="删除"
      variant="danger"
    />
    </>
  );
}
